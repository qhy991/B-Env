# Copy to config/paths.env and edit for your machine:
#   cp config/paths.env.example config/paths.env
#
# These paths are sourced by scripts/env.sh

# Live SGLang source tree (patch target)
export SGlang_PYTHON="${HOME}/sglang/python"

# Four-operator experiment monorepo root
export SGLANG_EXP_ROOT="${HOME}/sglang-exp"

# Shared Python venv (single venv for all workspaces)
export VENV_ROOT="${SGLANG_EXP_ROOT}/glm52-kernel-opt/.venv"

# NCU install (optional)
export NCU_ROOT="/opt/nvidia/nsight-compute/2026.1.1"

# Codex review proxy (Infini-AI via codex-transfer)
export CODEX_API_BASE="http://127.0.0.1:4446/v1"

# DeepGEMM source build (optional, for setup-env.sh --deep-gemm)
export DEEP_GEMM_REPO="https://github.com/deepseek-ai/DeepGEMM.git"
export DEEP_GEMM_REF="88965b0"
