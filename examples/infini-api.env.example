# Infini-AI API Key 与 Claude Code 路由配置
# 复制到 ~/.omp/agent/.env（或任意私有路径），填入真实 Key，并在 ~/.zshrc 中 source：
#
#   if [[ -f "$HOME/.omp/agent/.env" ]]; then
#     set -a; source "$HOME/.omp/agent/.env"; set +a
#   fi
#
# 切勿将含真实 Key 的文件提交到 git。

# --- Infini-AI GenStudio（Claude 与 codex-transfer 共用）---
GENSTUDIO_API_KEY=sk-your-infini-ai-key-here
CODEX_TRANSFER_API_KEY=sk-your-infini-ai-key-here

# --- Claude Code → Infini-AI（不是 api.anthropic.com）---
ANTHROPIC_BASE_URL=https://cloud.infini-ai.com/maas
ANTHROPIC_AUTH_TOKEN=sk-your-infini-ai-key-here
ANTHROPIC_API_KEY=sk-your-infini-ai-key-here

# 默认模型（会话内可用 /model 覆盖）
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash

# 可选：绕过 Codex bwrap 沙箱（部分共享主机必须开启）
# HUMANIZE_CODEX_BYPASS_SANDBOX=true
